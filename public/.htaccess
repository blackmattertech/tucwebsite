# SPA fallback for React Router (Vite build).
# On refresh, the server must serve index.html for client-side routes — otherwise you get 404.
# Copied to `dist/` from `public/` when you run `npm run build`.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Don't loop: real index.html passes through
  RewriteRule ^index\.html$ - [L]
  # Real files and folders (CSS, JS, images, PDFs) are served as-is
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # All other URLs → single-page app
  RewriteRule . /index.html [L]
</IfModule>
