# ---------------------------------------------------------------------------
# Public / client-safe only. Never put secret keys in VITE_* (they are bundled).
# ---------------------------------------------------------------------------

# App canonical base URL (optional; used for SEO canonical and sitemap). No trailing slash.
# Example: https://tucwebsite.vercel.app
VITE_APP_URL=https://tucwebsite.vercel.app

# Supabase (client-safe: project URL + anon key). Get from Supabase → Settings → API.
# Restrict via RLS; anon key is safe to expose in frontend.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Contact form API (if using Option B: external endpoint). Leave blank if using Supabase Option A.
VITE_CONTACT_API_URL=

# ImageKit (required for migration script: npm run migrate:supabase-to-imagekit)
# Get from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PRIVATE_KEY=your_private_key

# ImageKit URL for app (e.g. https://ik.imagekit.io/your_imagekit_id/)
# Used in imagekitStorage.ts - get from ImageKit dashboard after first upload
VITE_IMAGEKIT_URL=https://ik.imagekit.io/your_imagekit_id/
