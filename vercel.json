{
  "images": {
    "sizes": [256, 384, 400, 640, 750, 828, 1080, 1200, 1920, 2048],
    "minimumCacheTTL": 86400,
    "formats": ["image/webp", "image/avif"],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "ik.imagekit.io",
        "port": "",
        "pathname": "/**",
        "search": ""
      },
      {
        "protocol": "https",
        "hostname": "images.unsplash.com",
        "port": "",
        "pathname": "/**",
        "search": ""
      }
    ],
    "localPatterns": [
      {
        "pathname": "/**",
        "search": ""
      }
    ]
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/hero-poster.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/desktop/(.*).mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/mobile/(.*).mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logo.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
